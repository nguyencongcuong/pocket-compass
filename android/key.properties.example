# Copy to key.properties next to this file (android/key.properties) and fill in.
# Paths are relative to android/app/ when Gradle resolves storeFile.
#
# Create a keystore once, e.g.:
# keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
storePassword=
keyPassword=
keyAlias=upload
storeFile=upload-keystore.jks
